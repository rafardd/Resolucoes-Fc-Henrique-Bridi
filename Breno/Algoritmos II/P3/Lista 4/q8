---------------------------------

funcao maiorString(l:PNo): string
var
	maior: string
inicio
	se l = NULO entao
		retorne ""
	fim se
	maior <- maiorString(l^.prox)
	se l^.frase < maior entao
		retorne maior
	senao
		retorne l^.frase
	fim se
fim funcao

