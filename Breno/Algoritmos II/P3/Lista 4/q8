tipos
	PNo: ponteiro para TNo
	TNo: registro de
		frase: string
		prox: PNo
	     fim registro
funcao maiorString(l:PNo): string
var
	maior: string
inicio
	se l = nulo entao
		retorne ""
	fim se
	maior <- l^.frase
	l <- l^prox
	enquanto l != nulo faça
		se maior < l^.frase entao
			maior <- l^.frase
		fim se
		l <- l^.prox
	fim enquanto
	retorne maior
fim funcao
			
