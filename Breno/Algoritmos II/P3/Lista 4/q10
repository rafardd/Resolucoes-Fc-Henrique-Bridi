----------
iterativa
---------
funcao xJuntoDeY(l:PNo; x,y: real): logico
var
	encontroux, encontrouy: logico
inicio
	se l = NULO entao
		retorne FALSO
	fim se
	se l^.prox = NULO entao
		retorne falso
	fim se
	encontroux <- FALSO
	encontrouy <- FALSO
	enquanto l != NULO faça
		// Se ainda não achou x, continua procurando por ele
    		se nao encontroux e l^.elem = x entao
        		encontroux <- VERDADEIRO
    		fim se
    
    		// SÓ procura por y se o x JÁ tiver sido encontrado antes!
    		se encontroux e l^.elem = y entao
        		encontrouy <- VERDADEIRO
    		fim se
   		l <- l^.prox
	fim enquanto	
	retorne encontroux e encontrouy
fim funcao


