RECURSAO
------------

funcao buscarY (l: PNo; y: real): logico
inicio
	se l = NULO entao
		retorne FALSO
	fim se
	se l^.elem = y entao
		retorne VERDADEIRO
	fim se
	retorne buscarY(l^.prox, y)
fim funcao

funcao xAntesDeY(l: PNo; x, y: real): logico
inicio
	se l = NULO entao
		retorne FALSO
	fim se
	se l^.elem = x entao
		retorne buscarY(l^.prox,y)
	fim se
	retorne xAntesDeY(l^.prox, x, y)
fim funcao
