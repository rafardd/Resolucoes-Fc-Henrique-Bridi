-------------
iterativa
------------
funcao xJuntoDeY (l:PNo; x,y: real): logico
var
	ant: PNo
	encontrou: logico
inicio
	se l = NULO entao
		retorne FALSO
	fim se
	se l^.prox = NULO
		retorne FALSO
	fim se
	ant <- l
	l <- l^.prox
	encontrou <- FALSO
	enquanto l != nulo e nao encontrou faça
		encontrou <- ant^.elem = x e l^.elem = y
		se nao encontrou entao
			ant <- l
			l <- l^.prox
		fim se
	fim enquanto
	retorne encontrou
fim funcao

----------
RECURSIVA
----------

funcao xJuntoDeY (l:PNo; x,y:real): logico
inicio
	se l = nulo entao
		retorne FALSO
	fim se
	se l^prox = NULO entao
		retorne FALSO
	fim se
	se l^.elem = x e l^.prox^.elem = y entao
		retorne VERDADEIRO
	fim se
	retorne xJuntoDeY(l^.prox)
fim funcao	
