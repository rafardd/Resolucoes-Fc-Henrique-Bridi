funcao elementoPosicaoP(l: PNo, p: inteiro): string
inicio
	se p <= 0 entao
		retorne ""
	fim se
	enquanto l != nulo e p > 1 entao
		l <- l^.prox
		p <- p - 1
	fim enquanto
	se l = nulo entao
		retorne ""
	fim se
	retorne l^.frase
fim funcao
