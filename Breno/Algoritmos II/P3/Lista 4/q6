funcao elementoPosicaoP(l: PNo, p: inteiro): string
inicio
	se p <= 0 entao
		retorne ""
	fim se
	se l = nulo entao
		retorne ""
	fim se
	se p = 1 entao
		retorne l^.frase
	fim se
	retorne elementoPosicaoP(l^.prox, p-1)
fim funcao
