funcao encontrarElemento(l:PNo, x: real): logico
inicio
	se l = nulo entao 
		retorne FALSO
	fim se
	se l^.elemento = x entao
		retorne VERDADEIRO
	fim se
	retorne encontrarElemento(l^.prox, x)
fim funcao
