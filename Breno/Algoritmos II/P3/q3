tipos
	PNo: ponteiros de TNo
	TNo: registro de
	    	elemento: real
	     	prox: PNo
	     fim registro
funcao encontrarElemento(l:PNO, x: real): logico
var
	encontrou: logico
inicio
	encontrou <- FALSO
	enquanto l != nulo e nao encontrou entao
		encontrou <- l^.elemento = x
		l <- l^.prox
	fim enquanto
	retorne encontrou
fim funcao

