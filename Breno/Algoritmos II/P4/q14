funcao mediana(s:string): logico
var
	f: sequencia de inteiro
	i,qnt,valor,n,nAnterior: inteiro
	e_par: logico	
inicio
	para i de 0 até 3000 faça
		v[i] <- 0
	fim para
	se abre(f,s) entao
		qnt <- 0
		enquanto nao fds(f) faça
			leia(f, valor)
			v[valor] <- v[valor] + 1
			qnt <- qnt + 1
		fim enquanto
		fecha(f)
	senao
		retorna -99999999
	fim se
	é_par <- qnt div 2 = 0
	i <- 1
	n <- 0
	nAnterior <- 0
	enquanto i <= qnt div 2 + 1 faça
		se v[n] = 0 entao
			n <- n + 1
		senao
			v[n] <- v[n] - 1
			se i = qnt div 2 entao
				nAnterior <- n
			fim se
			i <- i + 1
		fim se
	fim enquanto
	se é_par entao
		retorne (n + nAnterior)/2
	senao
		retorne n
	fim se
fim funcao
