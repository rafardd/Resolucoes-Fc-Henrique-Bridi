funcao Media(s: string): real
var
        qnt, soma, x: inteiro
        f: sequencia de inteiro
inicio
        soma <- 0
        qnt <- 0
        se abre(f,s) entao
                enquanto não fds faça
                        leia(f,x)
                        qnt <- qnt + 1
                        soma <- soma + x
                fim enquanto
                fecha(f)
                se qnt != 0 entao
                        retorne soma/qnt
                fim se
        fim se
        retorne -999999999
fim funcao
